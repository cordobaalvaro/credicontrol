# Variables de entorno del Backend — CrediControl
# Copiá este archivo como .env y completá los valores

PORT=5000

# MongoDB Atlas
MONGO_ACCESS=mongodb+srv://<usuario>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# JWT — generá secretos largos y aleatorios (ej: openssl rand -hex 64)
JWT_ACCESS_SECRET=tu_access_secret_muy_largo
JWT_REFRESH_SECRET=tu_refresh_secret_muy_largo
ACCESS_TOKEN_TTL=10m
REFRESH_TOKEN_TTL=7d
REFRESH_COOKIE_NAME=rtoken

# Cloudinary (opcional — necesario para subir documentos de clientes)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Cron de actualización de préstamos (por defecto: medianoche todos los días)
PRESTAMOS_CRON=0 0 * * *

# Entorno (production activa Secure + SameSite=None en las cookies)
NODE_ENV=development
